<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>dev.sahiny.charge-alert</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/charge-alert</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardErrorPath</key>
    <string>/tmp/charge-alert.err.log</string>
    <key>StandardOutPath</key>
    <string>/tmp/charge-alert.out.log</string>
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
